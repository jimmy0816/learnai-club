---
interface Props {
  title: string;
  description: string;
  tools: string[];
  pitfall: string;
  status: string;
}
const { title, description, tools, pitfall, status } = Astro.props;
const statusColors: Record<string, string> = {
  '跑中': 'bg-green-500/20 text-green-400',
  '實驗中': 'bg-yellow-500/20 text-yellow-400',
  '上架中': 'bg-blue-500/20 text-blue-400',
  '規劃中': 'bg-purple-500/20 text-purple-400',
};
const statusClass = statusColors[status] || 'bg-gray-500/20 text-gray-400';
---
<div class="rounded-lg border border-[var(--border)] bg-[var(--card)] p-5 hover:border-[var(--accent)]/40 transition-colors">
  <div class="flex items-start justify-between gap-3 mb-3">
    <h3 class="text-base font-semibold text-[var(--text)]">{title}</h3>
    <span class:list={['shrink-0 text-xs font-medium px-2 py-0.5 rounded-full', statusClass]}>{status}</span>
  </div>
  <p class="text-sm text-[var(--muted)] mb-3">{description}</p>
  <div class="mb-3">
    <p class="text-xs text-[var(--accent)] font-medium mb-1">🔧 工具</p>
    <div class="flex flex-wrap gap-1.5">
      {tools.map(t => <span class="text-xs bg-[var(--accent-dim)] text-[var(--accent)] px-2 py-0.5 rounded">{t}</span>)}
    </div>
  </div>
  <div>
    <p class="text-xs text-red-400 font-medium mb-1">💥 踩坑</p>
    <p class="text-sm text-[var(--muted)]">{pitfall}</p>
  </div>
</div>
