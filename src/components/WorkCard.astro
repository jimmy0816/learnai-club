---
interface Props {
  title: string;
  description: string;
  tools: string[];
  pitfall: string;
  status: string;
  size?: 'normal' | 'large';
}
const { title, description, tools, pitfall, status, size = 'normal' } = Astro.props;

const statusColors: Record<string, string> = {
  '跑中': 'bg-green-500/20 text-green-400 border-green-500/30',
  '實驗中': 'bg-yellow-500/20 text-yellow-400 border-yellow-500/30',
  '上架中': 'bg-blue-500/20 text-blue-400 border-blue-500/30',
  '規劃中': 'bg-purple-500/20 text-purple-400 border-purple-500/30',
};
const statusClass = statusColors[status] || 'bg-gray-500/20 text-gray-400 border-gray-500/30';

const cardWidth = size === 'large' ? 'w-80 md:w-96' : 'w-64 md:w-72';
---
<div class:list={[
  'netflix-card relative rounded-md bg-[var(--card)] overflow-hidden cursor-pointer group',
  cardWidth
]}>
  <!-- Card top color bar based on status -->
  <div class:list={[
    'h-1 w-full',
    status === '跑中' ? 'bg-green-500' :
    status === '實驗中' ? 'bg-yellow-500' :
    status === '上架中' ? 'bg-blue-500' :
    status === '規劃中' ? 'bg-purple-500' : 'bg-gray-500'
  ]}></div>

  <!-- Main content -->
  <div class="p-4">
    <div class="flex items-start justify-between gap-2 mb-2">
      <h3 class="text-base font-bold text-[var(--text)] leading-tight">{title}</h3>
      <span class:list={['shrink-0 text-[10px] font-medium px-2 py-0.5 rounded border', statusClass]}>{status}</span>
    </div>
    <p class="text-sm text-[var(--muted)] line-clamp-2 mb-3">{description}</p>

    <!-- Hover reveal content -->
    <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-300">
      <div class="mb-3">
        <p class="text-xs text-[var(--accent)] font-semibold mb-1">🔧 工具</p>
        <div class="flex flex-wrap gap-1">
          {tools.slice(0, 3).map(t => <span class="text-[10px] bg-[var(--accent-dim)] text-[var(--accent)] px-1.5 py-0.5 rounded">{t}</span>)}
          {tools.length > 3 && <span class="text-[10px] text-[var(--muted)]">+{tools.length - 3}</span>}
        </div>
      </div>
      <div>
        <p class="text-xs text-red-400 font-semibold mb-1">💥 踩坑</p>
        <p class="text-xs text-[var(--muted)] line-clamp-2">{pitfall}</p>
      </div>
    </div>
  </div>
</div>
