---
interface Props {
  title: string;
  description: string;
  tools: string[];
  pitfall: string;
  status: string;
  poster: string;
  size?: 'normal' | 'large';
}
const { title, description, tools, pitfall, status, poster, size = 'normal' } = Astro.props;

const statusColors: Record<string, string> = {
  '跑中': 'bg-green-500/20 text-green-400 border-green-500/30',
  '實驗中': 'bg-yellow-500/20 text-yellow-400 border-yellow-500/30',
  '上架中': 'bg-blue-500/20 text-blue-400 border-blue-500/30',
  '規劃中': 'bg-purple-500/20 text-purple-400 border-purple-500/30',
};
const statusClass = statusColors[status] || 'bg-gray-500/20 text-gray-400 border-gray-500/30';

// 海報卡片尺寸（在 netflix-row 中固定寬度，在 grid 中自適應）
const cardWidth = size === 'large' ? 'w-full min-w-[340px] md:min-w-0' : 'w-[280px]';
const cardHeight = 'aspect-video'; // 16:9 比例，自適應高度
---
<div class:list={[
  'netflix-card relative rounded-lg overflow-hidden cursor-pointer group',
  cardWidth,
  cardHeight
]}>
  <!-- 海報圖片背景 -->
  <div class="absolute inset-0">
    <img 
      src={poster} 
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
    />
  </div>

  <!-- 底部漸層遮罩（預設狀態） -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent opacity-100 group-hover:opacity-0 transition-opacity duration-300"></div>

  <!-- 預設顯示：底部標題 + 狀態 -->
  <div class="absolute bottom-0 left-0 right-0 p-4 opacity-100 group-hover:opacity-0 transition-opacity duration-300">
    <div class="flex items-start justify-between gap-2 mb-1">
      <h3 class="text-sm md:text-base font-bold text-white leading-tight">{title}</h3>
      <span class:list={['shrink-0 text-[10px] font-medium px-2 py-0.5 rounded border', statusClass]}>{status}</span>
    </div>
  </div>

  <!-- Hover 顯示：完整資訊覆蓋 -->
  <div class="absolute inset-0 bg-gradient-to-t from-black via-black/85 to-black/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 p-4 flex flex-col justify-end">
    <div class="flex items-start justify-between gap-2 mb-2">
      <h3 class="text-sm md:text-base font-bold text-white leading-tight">{title}</h3>
      <span class:list={['shrink-0 text-[10px] font-medium px-2 py-0.5 rounded border', statusClass]}>{status}</span>
    </div>
    
    <p class="text-xs md:text-sm text-gray-300 line-clamp-2 mb-3">{description}</p>

    <div class="mb-2">
      <p class="text-[10px] text-[var(--accent)] font-semibold mb-1">🔧 工具</p>
      <div class="flex flex-wrap gap-1">
        {tools.slice(0, 4).map(t => <span class="text-[9px] md:text-[10px] bg-white/10 text-white px-1.5 py-0.5 rounded">{t}</span>)}
        {tools.length > 4 && <span class="text-[10px] text-gray-400">+{tools.length - 4}</span>}
      </div>
    </div>

    <div>
      <p class="text-[10px] text-red-400 font-semibold mb-1">💥 踩坑</p>
      <p class="text-[10px] md:text-xs text-gray-400 line-clamp-2">{pitfall}</p>
    </div>
  </div>
</div>
