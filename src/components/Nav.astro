---
const links = [
  { href: '/', label: '首頁' },
  { href: '/works', label: '成果集' },
  { href: '/blog', label: 'Blog' },
  { href: '/courses', label: '開課' },
  { href: '/about', label: '關於' },
];
const current = Astro.url.pathname;
---
<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 nav-transparent">
  <div class="max-w-7xl mx-auto px-6 md:px-12 h-16 flex items-center justify-between">
    <a href="/" class="text-xl font-bold text-[var(--accent)] hover:text-[var(--accent-hover)] transition-colors">
      learnai<span class="text-[var(--text)]">.club</span>
    </a>
    <!-- Desktop -->
    <div class="hidden md:flex gap-8">
      {links.map(l => (
        <a href={l.href}
           class:list={['text-sm font-medium transition-colors',
             current === l.href || (l.href !== '/' && current.startsWith(l.href))
               ? 'text-[var(--text)]'
               : 'text-[var(--muted)] hover:text-[var(--text)]'
           ]}>
          {l.label}
        </a>
      ))}
    </div>
    <!-- Mobile hamburger -->
    <button id="menu-btn" class="md:hidden text-[var(--muted)] hover:text-[var(--text)]" aria-label="選單">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>
  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-[var(--bg)]/95 backdrop-blur-md">
    {links.map(l => (
      <a href={l.href}
         class:list={['block px-6 py-4 text-sm font-medium border-b border-[var(--border)]',
           current === l.href ? 'text-[var(--text)]' : 'text-[var(--muted)]'
         ]}>
        {l.label}
      </a>
    ))}
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  // Scroll effect: transparent -> solid
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      nav?.classList.remove('nav-transparent');
      nav?.classList.add('nav-solid');
    } else {
      nav?.classList.remove('nav-solid');
      nav?.classList.add('nav-transparent');
    }
  });

  // Mobile menu toggle
  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
