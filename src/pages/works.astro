---
import Layout from '../layouts/Layout.astro';
import WorkCard from '../components/WorkCard.astro';
import works from '../data/works.json';

// 分類作品
const running = works.filter(w => w.status === '跑中');
const launched = works.filter(w => w.status === '上架中');
const experimental = works.filter(w => w.status === '實驗中' || w.status === '規劃中');
---
<Layout title="成果集">
  <!-- Hero section -->
  <section class="relative py-16 md:py-20 px-4 md:px-6 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-3 md:mb-4">成果集</h1>
      <p class="text-base md:text-lg lg:text-xl text-[var(--muted)] max-w-2xl">
        這些不是 demo，是每天在跑的系統。每個都踩過坑，每個都有故事。
      </p>
    </div>
  </section>

  <!-- Grid layout for posters -->
  <div class="pb-20 space-y-10 md:space-y-12">
    <!-- 🟢 跑中 -->
    <section class="px-4 md:px-6 lg:px-12">
      <h2 class="text-lg md:text-xl lg:text-2xl font-bold text-white mb-4 md:mb-6 flex items-center gap-2">
        <span class="w-2.5 h-2.5 md:w-3 md:h-3 rounded-full bg-green-500"></span>
        正在運行
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {running.map(w => <WorkCard {...w} size="large" />)}
      </div>
    </section>

    <!-- 🔵 上架中 -->
    {launched.length > 0 && (
      <section class="px-4 md:px-6 lg:px-12">
        <h2 class="text-lg md:text-xl lg:text-2xl font-bold text-white mb-4 md:mb-6 flex items-center gap-2">
          <span class="w-2.5 h-2.5 md:w-3 md:h-3 rounded-full bg-blue-500"></span>
          已上架
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
          {launched.map(w => <WorkCard {...w} size="large" />)}
        </div>
      </section>
    )}

    <!-- 🟡 實驗中 -->
    {experimental.length > 0 && (
      <section class="px-4 md:px-6 lg:px-12">
        <h2 class="text-lg md:text-xl lg:text-2xl font-bold text-white mb-4 md:mb-6 flex items-center gap-2">
          <span class="w-2.5 h-2.5 md:w-3 md:h-3 rounded-full bg-yellow-500"></span>
          實驗中
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
          {experimental.map(w => <WorkCard {...w} size="large" />)}
        </div>
      </section>
    )}
  </div>
</Layout>
