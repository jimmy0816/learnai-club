---
import BaseLayout from '../../layouts/BaseLayout.astro';

const postModules = import.meta.glob('../../content/blog/*.mdx', { eager: true }) as Record<string, any>;
const posts = Object.entries(postModules)
  .map(([file, mod]) => {
    const slug = file.split('/').pop()!.replace(/\.mdx?$/, '');
    return { slug, ...mod.frontmatter };
  })
  .filter((p) => !p.draft)
  .sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());
---
<BaseLayout
  title="AI 導入洞察部落格"
  description="分享台灣企業 AI 導入實戰經驗、案例分析，以及最新 AI 工具評測。"
>
  <section class="section" style="background: #1e3a5f;">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center py-12">
        <div class="text-5xl mb-6">📝</div>
        <h1 class="text-4xl md:text-5xl font-black text-white mb-6" style="font-family: 'Noto Sans TC', sans-serif;">
          AI 洞察部落格
        </h1>
        <p class="text-xl text-white/80">
          台灣企業 AI 導入實戰經驗、案例分析與工具評測
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="max-w-3xl mx-auto py-12">
        <div class="grid gap-8">
          {posts.map((post) => (
            <a href={`/blog/${post.slug}`} class="block group">
              <article class="bg-[var(--card)] border border-white/10 rounded-2xl p-8 hover:border-[var(--accent)]/50 transition-all">
                <div class="flex items-center gap-3 mb-3 flex-wrap">
                  <time class="text-sm text-[var(--muted)]">
                    {new Date(post.date).toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                  {post.tags?.slice(0, 3).map((tag: string) => (
                    <span class="text-xs bg-[var(--accent-dim)] text-[var(--accent)] px-2 py-0.5 rounded">{tag}</span>
                  ))}
                </div>
                <h2 class="text-xl font-bold text-[var(--text)] mb-3 group-hover:text-[var(--accent)] transition-colors">
                  {post.title}
                </h2>
                <p class="text-[var(--muted)] leading-relaxed">{post.description}</p>
                <div class="mt-4 text-[var(--accent)] text-sm font-medium">閱讀文章 →</div>
              </article>
            </a>
          ))}
        </div>

        {posts.length === 0 && (
          <div class="text-center text-[var(--muted)] py-12">
            <p>文章即將上線，敬請期待。</p>
          </div>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
