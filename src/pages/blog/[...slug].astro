---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = import.meta.glob('../../content/blog/*.mdx', { eager: true }) as Record<string, any>;
  return Object.entries(posts).map(([file, mod]) => {
    const slug = file.split('/').pop()!.replace(/\.mdx?$/, '');
    return { params: { slug }, props: { post: mod } };
  });
}

const { post } = Astro.props;
const { Content, frontmatter } = post;
---
<Layout title={frontmatter.title} description={frontmatter.description}>
  <article class="max-w-3xl mx-auto px-4 pt-12 pb-20">
    <a href="/blog" class="text-sm text-[var(--accent)] mb-6 inline-block">← 回到 Blog</a>
    <div class="flex items-center gap-3 mb-4">
      <time class="text-sm text-[var(--muted)]">{new Date(frontmatter.date).toLocaleDateString('zh-TW')}</time>
      {frontmatter.tags?.map((tag: string) => (
        <span class="text-xs bg-[var(--accent-dim)] text-[var(--accent)] px-2 py-0.5 rounded">{tag}</span>
      ))}
    </div>
    <h1 class="text-3xl font-bold mb-8">{frontmatter.title}</h1>
    <div class="prose prose-invert max-w-none
                prose-headings:text-[var(--text)] prose-headings:font-bold
                prose-p:text-[var(--muted)] prose-p:leading-relaxed
                prose-strong:text-[var(--text)]
                prose-code:text-[var(--accent)] prose-code:bg-[var(--card)] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
                prose-li:text-[var(--muted)]
                prose-a:text-[var(--accent)]">
      <Content />
    </div>
  </article>
</Layout>
