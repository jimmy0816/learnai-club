---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = import.meta.glob('../../content/blog/*.mdx', { eager: true }) as Record<string, any>;
  return Object.entries(posts).map(([file, mod]) => {
    const slug = file.split('/').pop()!.replace(/\.mdx?$/, '');
    return { params: { slug }, props: { post: mod } };
  });
}

const { post } = Astro.props;
const { Content, frontmatter } = post;
---
<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <article style="max-width: 720px; margin: 0 auto; padding: 56px 20px 32px;">
    <a href="/blog" style="font-size: 13px; color: var(--color-accent); display: inline-block; margin-bottom: 32px; text-decoration: none; letter-spacing: 0.02em;">← 回到 Blog</a>

    <h1 style="font-family: var(--font-heading); font-size: clamp(24px, 4.5vw, 38px); font-weight: 700; color: var(--color-text); margin: 0 0 20px; line-height: 1.2; letter-spacing: -0.02em;">
      {frontmatter.title}
    </h1>

    <!-- Meta: date + tags -->
    <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 12px; margin-bottom: 48px; padding-bottom: 24px; border-bottom: 1px solid var(--color-border);">
      <time style="font-size: 13px; color: var(--color-text-secondary);">
        {new Date(frontmatter.date).toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {frontmatter.tags?.map((tag: string) => (
        <span style="font-size: 11px; background: var(--color-bg-section); color: var(--color-accent); padding: 3px 10px; border-radius: 2px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase;">{tag}</span>
      ))}
    </div>

    <div class="article-content">
      <Content />
    </div>
  </article>

  <!-- Fixed CTA Block -->
  <section style="max-width: 720px; margin: 0 auto; padding: 0 20px 80px;">
    <div style="border-top: 1px solid var(--color-border); padding-top: 48px; display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px;">
      <div style="background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 28px; text-align: center;">
        <h3 style="font-family: var(--font-heading); font-size: 17px; font-weight: 600; color: var(--color-text); margin-bottom: 10px; line-height: 1.4;">不確定你的公司該從哪個開始？</h3>
        <p style="color: var(--color-text-secondary); font-size: 14px; margin-bottom: 20px; line-height: 1.7;">2 分鐘免費 AI 健檢，找出最值得自動化的 3 個流程。</p>
        <a href="/ai-checkup" class="btn-primary" style="justify-content: center;">
          免費 AI 健檢 →
        </a>
      </div>
      <div style="background: var(--color-bg-alt); border: 1px solid var(--color-border); border-bottom: 2px solid var(--color-primary); border-radius: var(--radius-md); padding: 28px; text-align: center;">
        <h3 style="font-family: var(--font-heading); font-size: 17px; font-weight: 600; color: var(--color-text); margin-bottom: 10px; line-height: 1.4;">需要專人幫你導入？</h3>
        <p style="color: var(--color-text-secondary); font-size: 14px; margin-bottom: 20px; line-height: 1.7;">預約免費 30 分鐘諮詢，直接跟顧問聊你的狀況。</p>
        <a href="/consult" class="btn-primary" style="justify-content: center;">
          預約免費諮詢 →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
