---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = import.meta.glob('../../content/blog/*.mdx', { eager: true }) as Record<string, any>;
  return Object.entries(posts).map(([file, mod]) => {
    const slug = file.split('/').pop()!.replace(/\.mdx?$/, '');
    return { params: { slug }, props: { post: mod } };
  });
}

const { post } = Astro.props;
const { Content, frontmatter } = post;
---
<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <article style="max-width: 720px; margin: 0 auto; padding: 40px 20px 24px;">
    <a href="/blog" style="font-size: 14px; color: #f97316; display: inline-block; margin-bottom: 24px; text-decoration: none;">← 回到 Blog</a>

    <h1 style="font-size: clamp(24px, 5vw, 36px); font-weight: 900; color: #1e3a5f; margin: 0 0 16px; line-height: 1.3; font-family: 'Noto Sans TC', sans-serif;">
      {frontmatter.title}
    </h1>

    <!-- Meta: date + tags -->
    <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 12px; margin-bottom: 40px; padding-bottom: 24px; border-bottom: 1px solid #e5e7eb;">
      <time style="font-size: 14px; color: #6b7280;">
        {new Date(frontmatter.date).toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {frontmatter.tags?.map((tag: string) => (
        <span style="font-size: 12px; background: #fff7ed; color: #f97316; padding: 3px 10px; border-radius: 20px; font-weight: 600;">{tag}</span>
      ))}
    </div>

    <div class="article-content">
      <Content />
    </div>
  </article>

  <!-- Fixed CTA Block -->
  <section class="max-w-3xl mx-auto px-4 pb-20">
    <div class="mt-12 grid md:grid-cols-2 gap-6">
      <div class="bg-[var(--card)] border border-white/10 rounded-2xl p-8 text-center">
        <div class="text-3xl mb-4">🔍</div>
        <h3 class="text-lg font-bold text-[var(--text)] mb-3">不確定你的公司該從哪個開始？</h3>
        <p class="text-[var(--muted)] text-sm mb-6">2 分鐘免費 AI 健檢，找出最值得自動化的 3 個流程。</p>
        <a href="/ai-checkup" class="btn-primary inline-block">
          免費 AI 健檢 →
        </a>
      </div>
      <div class="bg-[var(--card)] border border-[var(--accent)]/30 rounded-2xl p-8 text-center">
        <div class="text-3xl mb-4">💬</div>
        <h3 class="text-lg font-bold text-[var(--text)] mb-3">需要專人幫你導入？</h3>
        <p class="text-[var(--muted)] text-sm mb-6">預約免費 30 分鐘諮詢，直接跟顧問聊你的狀況。</p>
        <a href="/consult" class="btn-primary inline-block">
          預約免費諮詢 →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
