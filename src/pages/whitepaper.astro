---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="免費下載：2026 台灣企業 AI 導入白皮書"
  description="10 個產業 AI 應用案例 × ROI 計算模型 × 30/60/90 天導入路線圖 × 20 個免費 AI 工具清單。填寫 Email 立即免費取得。"
>

  <section style="background: #111111; padding: 72px 20px 56px;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 56px;">
        <p style="font-size: 11px; font-weight: 700; color: var(--color-gold); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 20px;">免費白皮書 · 2026 年最新版</p>
        <h1 style="font-family: var(--font-heading); font-size: clamp(26px, 4vw, 44px); font-weight: 700; color: #f5f0e8; line-height: 1.2; margin-bottom: 16px; letter-spacing: -0.02em;">
          2026 台灣企業 AI 導入<br />實戰白皮書
        </h1>
        <p style="font-size: 16px; color: rgba(245,240,232,0.5); line-height: 1.7;">
          10 個產業 × AI 應用案例 × ROI 計算 × 30/60/90 天路線圖
        </p>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; max-width: 900px; margin: 0 auto;">

        <!-- 左：封面預覽 -->
        <div style="display: flex; flex-direction: column; align-items: center;">
          <!-- 白皮書封面卡片 -->
          <div class="whitepaper-cover-card">
            <div class="cover-badge">免費下載</div>
            <div class="cover-logo">Learn AI Club × AutoLab</div>
            <div class="cover-year">2026</div>
            <h2 class="cover-title">台灣企業 AI 導入<br />實戰白皮書</h2>
            <p class="cover-subtitle">10 個產業 × AI 應用案例<br />ROI 計算 × 30/60/90 天路線圖</p>
            <div class="cover-divider"></div>
            <div class="cover-features">
              <span>製造業</span>
              <span>零售電商</span>
              <span>餐飲業</span>
              <span>物流</span>
              <span>金融保險</span>
              <span>醫療</span>
            </div>
            <div class="cover-pages">約 20 頁 · 繁體中文</div>
          </div>

          <!-- 白皮書包含什麼 -->
          <div style="margin-top: 32px; width: 100%; max-width: 300px;">
            <h3 style="font-size: 11px; font-weight: 600; color: rgba(245,240,232,0.4); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 16px;">白皮書包含</h3>
            <ul style="display: flex; flex-direction: column; gap: 12px; list-style: none; padding: 0; margin: 0;">
              {[
                '10 個產業 AI 應用案例（含真實工具和效益數字）',
                'ROI 計算模型（3 種規模試算範例）',
                '30/60/90 天導入路線圖（可直接執行）',
                '20 個免費 AI 工具清單（按用途分類）',
                '為什麼 2026 是企業導入 AI 的關鍵年',
              ].map(item => (
                <li style="display: flex; align-items: flex-start; gap: 10px; color: rgba(245,240,232,0.6); font-size: 14px; line-height: 1.6;">
                  <span style="color: var(--color-gold); flex-shrink: 0; margin-top: 2px;">✓</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- 右：表單 -->
        <div>
          <div style="background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 40px 36px; box-shadow: var(--shadow-sm);">
            <h2 style="font-family: var(--font-heading); font-size: 22px; font-weight: 600; color: var(--color-text); margin: 0 0 8px;">
              免費取得白皮書
            </h2>
            <p style="color: var(--color-text-secondary); font-size: 14px; margin-bottom: 28px; line-height: 1.6;">填寫以下資訊，立即取得線上版白皮書</p>

            <form id="whitepaper-form" novalidate>
              <!-- Email -->
              <div style="margin-bottom: 18px;">
                <label for="email" style="display: block; font-size: 13px; font-weight: 600; color: var(--color-text); margin-bottom: 8px; letter-spacing: 0.02em;">
                  Email 地址 <span style="color: #cc4444;">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="your@company.com"
                  required
                  style="width: 100%; padding: 12px 16px; border: 1px solid var(--color-border); border-radius: var(--radius-sm); font-size: 15px; color: var(--color-text); background: var(--color-bg); box-sizing: border-box; transition: border-color 0.2s; outline: none; font-family: var(--font-body);"
                  onfocus="this.style.borderColor='var(--color-primary)'; this.style.background='white';"
                  onblur="this.style.borderColor='var(--color-border)'; this.style.background='var(--color-bg)';"
                />
                <p id="email-error" style="display: none; color: #cc4444; font-size: 12px; margin-top: 6px;">請填寫有效的 Email 地址</p>
              </div>

              <!-- 公司名稱 -->
              <div style="margin-bottom: 18px;">
                <label for="company" style="display: block; font-size: 13px; font-weight: 600; color: var(--color-text); margin-bottom: 8px; letter-spacing: 0.02em;">
                  公司名稱 <span style="color: var(--color-text-secondary); font-weight: 400;">（選填）</span>
                </label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  placeholder="例：台灣科技股份有限公司"
                  style="width: 100%; padding: 12px 16px; border: 1px solid var(--color-border); border-radius: var(--radius-sm); font-size: 15px; color: var(--color-text); background: var(--color-bg); box-sizing: border-box; transition: border-color 0.2s; outline: none; font-family: var(--font-body);"
                  onfocus="this.style.borderColor='var(--color-primary)'; this.style.background='white';"
                  onblur="this.style.borderColor='var(--color-border)'; this.style.background='var(--color-bg)';"
                />
              </div>

              <!-- 職稱 -->
              <div style="margin-bottom: 28px;">
                <label for="job_title" style="display: block; font-size: 13px; font-weight: 600; color: var(--color-text); margin-bottom: 8px; letter-spacing: 0.02em;">
                  職稱 <span style="color: var(--color-text-secondary); font-weight: 400;">（選填）</span>
                </label>
                <input
                  type="text"
                  id="job_title"
                  name="job_title"
                  placeholder="例：總經理、IT 主管、業務副理"
                  style="width: 100%; padding: 12px 16px; border: 1px solid var(--color-border); border-radius: var(--radius-sm); font-size: 15px; color: var(--color-text); background: var(--color-bg); box-sizing: border-box; transition: border-color 0.2s; outline: none; font-family: var(--font-body);"
                  onfocus="this.style.borderColor='var(--color-primary)'; this.style.background='white';"
                  onblur="this.style.borderColor='var(--color-border)'; this.style.background='var(--color-bg)';"
                />
              </div>

              <!-- 提交按鈕 -->
              <button
                type="submit"
                id="submit-btn"
                class="btn-primary"
                style="width: 100%; justify-content: center; font-size: 15px; padding: 15px 32px;"
              >
                <span id="btn-text">免費下載白皮書 →</span>
                <span id="btn-loading" style="display: none;">處理中...</span>
              </button>

              <!-- 錯誤訊息 -->
              <div id="form-error" style="display: none; margin-top: 16px; padding: 12px 16px; background: #fff0f0; border: 1px solid #e8b4b4; border-radius: var(--radius-sm); color: #c44; font-size: 14px; text-align: center;"></div>

              <p style="color: var(--color-text-secondary); font-size: 12px; text-align: center; margin-top: 16px; opacity: 0.6;">
                不發垃圾郵件，不分享你的資料
              </p>
            </form>
          </div>

          <!-- 已有多少人下載 -->
          <p style="text-align: center; color: rgba(245,240,232,0.4); font-size: 13px; margin-top: 16px;">
            已有 <span style="color: rgba(245,240,232,0.7); font-weight: 600;">312</span> 位企業主下載
          </p>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .whitepaper-cover-card {
    width: 260px;
    height: 360px;
    background: #111111;
    border: 1px solid var(--color-gold);
    border-radius: var(--radius-md);
    padding: 28px 24px;
    position: relative;
    display: flex;
    flex-direction: column;
    color: white;
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
  }

  .whitepaper-cover-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--color-gold);
  }

  .cover-badge {
    display: inline-block;
    background: transparent;
    border: 1px solid var(--color-gold);
    color: var(--color-gold);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 2px;
    margin-bottom: 12px;
    width: fit-content;
    font-family: var(--font-body);
  }

  .cover-logo {
    font-size: 10px;
    color: rgba(255,255,255,0.3);
    margin-bottom: 8px;
    letter-spacing: 0.05em;
    font-family: var(--font-body);
  }

  .cover-year {
    font-family: 'Inter', sans-serif;
    font-size: 52px;
    font-weight: 700;
    color: rgba(184,154,90,0.08);
    line-height: 1;
    position: absolute;
    right: 14px;
    top: 36px;
    letter-spacing: -0.03em;
  }

  .cover-title {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 700;
    line-height: 1.3;
    color: #f5f0e8;
    margin-bottom: 8px;
    flex: 1;
  }

  .cover-subtitle {
    font-size: 10px;
    color: rgba(255,255,255,0.4);
    line-height: 1.7;
    margin-bottom: 16px;
    font-family: var(--font-body);
  }

  .cover-divider {
    height: 1px;
    background: rgba(184,154,90,0.3);
    margin-bottom: 12px;
  }

  .cover-features {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: 12px;
  }

  .cover-features span {
    font-size: 9px;
    color: rgba(255,255,255,0.35);
    background: rgba(255,255,255,0.04);
    padding: 2px 6px;
    border-radius: 2px;
    font-family: var(--font-body);
  }

  .cover-pages {
    font-size: 10px;
    color: rgba(184,154,90,0.6);
    text-align: right;
    margin-top: auto;
    font-family: var(--font-body);
    letter-spacing: 0.05em;
  }

  @media (max-width: 700px) {
    .whitepaper-cover-card {
      width: 220px;
      height: 300px;
    }
    section > div > div[style*="grid-template-columns: 1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<script>
  const form = document.getElementById('whitepaper-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text')!;
  const btnLoading = document.getElementById('btn-loading')!;
  const formError = document.getElementById('form-error')!;
  const emailError = document.getElementById('email-error')!;
  const emailInput = document.getElementById('email') as HTMLInputElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Clear previous errors
    formError.style.display = 'none';
    emailError.style.display = 'none';
    
    const email = emailInput.value.trim();
    const company = (document.getElementById('company') as HTMLInputElement).value.trim();
    const title = (document.getElementById('job_title') as HTMLInputElement).value.trim();
    
    // Validate email
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      emailError.style.display = 'block';
      emailInput.focus();
      return;
    }
    
    // Loading state
    submitBtn.disabled = true;
    btnText.style.display = 'none';
    btnLoading.style.display = 'inline';
    
    try {
      const res = await fetch('/api/whitepaper', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, company, title }),
      });
      
      const data = await res.json();
      
      if (data.success && data.redirect) {
        window.location.href = data.redirect;
      } else if (!res.ok) {
        throw new Error(data.error || '發生錯誤，請稍後再試');
      } else {
        window.location.href = '/whitepaper-content';
      }
    } catch (err: any) {
      formError.textContent = err.message || '發生錯誤，請稍後再試';
      formError.style.display = 'block';
      submitBtn.disabled = false;
      btnText.style.display = 'inline';
      btnLoading.style.display = 'none';
    }
  });
</script>
