---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="免費下載：2026 台灣企業 AI 導入白皮書"
  description="10 個產業 AI 應用案例 × ROI 計算模型 × 30/60/90 天導入路線圖 × 20 個免費 AI 工具清單。填寫 Email 立即免費取得。"
>

  <section class="section" style="background: linear-gradient(135deg, #1e3a5f 0%, #2a4f7c 50%, #1e3a5f 100%); min-height: 60vh;">
    <div class="container">
      <div class="text-center mb-4 pt-4">
        <div class="inline-flex items-center gap-2 bg-white/10 text-white/80 text-sm font-medium px-4 py-2 rounded-full mb-4">
          <span>📄</span>
          免費白皮書 · 2026 年最新版
        </div>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-white leading-tight mb-4" style="font-family: 'Noto Sans TC', sans-serif;">
          2026 台灣企業 AI 導入<br class="hidden md:block" />
          <span style="color: #f97316;">實戰白皮書</span>
        </h1>
        <p class="text-lg text-white/80 mb-8">
          10 個產業 × AI 應用案例 × ROI 計算 × 30/60/90 天路線圖
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start max-w-5xl mx-auto pb-12">

        <!-- 左：封面預覽 -->
        <div class="flex flex-col items-center">
          <!-- 白皮書封面卡片 -->
          <div class="whitepaper-cover-card">
            <div class="cover-badge">免費下載</div>
            <div class="cover-logo">📚 Learn AI Club × AutoLab</div>
            <div class="cover-year">2026</div>
            <h2 class="cover-title">台灣企業 AI 導入<br />實戰白皮書</h2>
            <p class="cover-subtitle">10 個產業 × AI 應用案例<br />ROI 計算 × 30/60/90 天路線圖</p>
            <div class="cover-divider"></div>
            <div class="cover-features">
              <span>✦ 製造業</span>
              <span>✦ 零售電商</span>
              <span>✦ 餐飲業</span>
              <span>✦ 物流</span>
              <span>✦ 金融保險</span>
              <span>✦ 醫療</span>
            </div>
            <div class="cover-pages">約 20 頁 · 繁體中文</div>
          </div>

          <!-- 白皮書包含什麼 -->
          <div class="mt-8 w-full max-w-sm">
            <h3 class="text-white/60 text-sm font-semibold uppercase tracking-wider mb-4">白皮書包含</h3>
            <ul class="space-y-3">
              {[
                '10 個產業 AI 應用案例（含真實工具和效益數字）',
                'ROI 計算模型（3 種規模試算範例）',
                '30/60/90 天導入路線圖（可直接執行）',
                '20 個免費 AI 工具清單（按用途分類）',
                '為什麼 2026 是企業導入 AI 的關鍵年',
              ].map(item => (
                <li class="flex items-start gap-3 text-white/80">
                  <span class="text-green-400 mt-0.5 flex-shrink-0">✅</span>
                  <span class="text-sm">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- 右：表單 -->
        <div>
          <div class="bg-white rounded-2xl p-8 shadow-2xl">
            <h2 class="text-2xl font-bold mb-2" style="color: #1e3a5f; font-family: 'Noto Sans TC', sans-serif;">
              免費取得白皮書
            </h2>
            <p class="text-gray-500 text-sm mb-6">填寫以下資訊，立即取得線上版白皮書</p>

            <form id="whitepaper-form" novalidate>
              <!-- Email -->
              <div class="mb-4">
                <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">
                  Email 地址 <span class="text-red-500">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="your@company.com"
                  required
                  class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:border-transparent transition-all"
                  style="focus-ring-color: #1e3a5f;"
                />
                <p id="email-error" class="text-red-500 text-xs mt-1 hidden">請填寫有效的 Email 地址</p>
              </div>

              <!-- 公司名稱 -->
              <div class="mb-4">
                <label for="company" class="block text-sm font-semibold text-gray-700 mb-1.5">
                  公司名稱 <span class="text-gray-400 font-normal">（選填）</span>
                </label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  placeholder="例：台灣科技股份有限公司"
                  class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:border-transparent transition-all"
                />
              </div>

              <!-- 職稱 -->
              <div class="mb-6">
                <label for="job_title" class="block text-sm font-semibold text-gray-700 mb-1.5">
                  職稱 <span class="text-gray-400 font-normal">（選填）</span>
                </label>
                <input
                  type="text"
                  id="job_title"
                  name="job_title"
                  placeholder="例：總經理、IT 主管、業務副理"
                  class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:border-transparent transition-all"
                />
              </div>

              <!-- 提交按鈕 -->
              <button
                type="submit"
                id="submit-btn"
                class="w-full py-4 rounded-xl font-bold text-lg text-white transition-all flex items-center justify-center gap-2"
                style="background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);"
              >
                <span id="btn-text">免費下載白皮書 →</span>
                <span id="btn-loading" class="hidden">
                  <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 22 6.477 22 12h-4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                  處理中...
                </span>
              </button>

              <!-- 錯誤訊息 -->
              <div id="form-error" class="hidden mt-4 p-3 bg-red-50 border border-red-200 rounded-xl text-red-600 text-sm text-center"></div>

              <p class="text-gray-400 text-xs text-center mt-4">
                🔒 我們不會發送垃圾郵件，也不會分享你的資料
              </p>
            </form>
          </div>

          <!-- 已有多少人下載 -->
          <div class="mt-4 text-center text-white/60 text-sm">
            📥 已有 <span class="text-white font-semibold">312</span> 位企業主下載
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .whitepaper-cover-card {
    width: 280px;
    height: 380px;
    background: linear-gradient(160deg, #1a3a6b 0%, #0f2447 60%, #0a1a38 100%);
    border-radius: 16px;
    padding: 28px 24px;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255,255,255,0.1);
    position: relative;
    display: flex;
    flex-direction: column;
    color: white;
    overflow: hidden;
  }

  .whitepaper-cover-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #f97316, #fbbf24);
  }

  .cover-badge {
    display: inline-block;
    background: rgba(249, 115, 22, 0.2);
    border: 1px solid rgba(249, 115, 22, 0.5);
    color: #fbbf24;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 20px;
    margin-bottom: 12px;
    width: fit-content;
  }

  .cover-logo {
    font-size: 10px;
    color: rgba(255,255,255,0.5);
    margin-bottom: 8px;
    letter-spacing: 0.05em;
  }

  .cover-year {
    font-size: 48px;
    font-weight: 900;
    color: rgba(255,255,255,0.08);
    line-height: 1;
    position: absolute;
    right: 16px;
    top: 40px;
    font-family: 'Inter', sans-serif;
  }

  .cover-title {
    font-size: 18px;
    font-weight: 900;
    line-height: 1.3;
    color: white;
    margin-bottom: 8px;
    font-family: 'Noto Sans TC', sans-serif;
    flex: 1;
  }

  .cover-subtitle {
    font-size: 10px;
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .cover-divider {
    height: 1px;
    background: rgba(255,255,255,0.1);
    margin-bottom: 12px;
  }

  .cover-features {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: 12px;
  }

  .cover-features span {
    font-size: 9px;
    color: rgba(255,255,255,0.5);
    background: rgba(255,255,255,0.05);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .cover-pages {
    font-size: 10px;
    color: rgba(249, 115, 22, 0.7);
    text-align: right;
    margin-top: auto;
  }

  input:focus {
    outline: none;
    ring-color: #1e3a5f;
    border-color: #1e3a5f;
    box-shadow: 0 0 0 3px rgba(30, 58, 95, 0.1);
  }

  #submit-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 25px rgba(249, 115, 22, 0.4);
  }

  #submit-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
  }
</style>

<script>
  const form = document.getElementById('whitepaper-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text')!;
  const btnLoading = document.getElementById('btn-loading')!;
  const formError = document.getElementById('form-error')!;
  const emailError = document.getElementById('email-error')!;
  const emailInput = document.getElementById('email') as HTMLInputElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Clear previous errors
    formError.classList.add('hidden');
    emailError.classList.add('hidden');
    
    const email = emailInput.value.trim();
    const company = (document.getElementById('company') as HTMLInputElement).value.trim();
    const title = (document.getElementById('job_title') as HTMLInputElement).value.trim();
    
    // Validate email
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      emailError.classList.remove('hidden');
      emailInput.focus();
      return;
    }
    
    // Loading state
    submitBtn.disabled = true;
    btnText.classList.add('hidden');
    btnLoading.classList.remove('hidden');
    
    try {
      const res = await fetch('/api/whitepaper', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, company, title }),
      });
      
      const data = await res.json();
      
      if (data.success && data.redirect) {
        window.location.href = data.redirect;
      } else if (!res.ok) {
        throw new Error(data.error || '發生錯誤，請稍後再試');
      } else {
        window.location.href = '/whitepaper-content';
      }
    } catch (err: any) {
      formError.textContent = err.message || '發生錯誤，請稍後再試';
      formError.classList.remove('hidden');
      submitBtn.disabled = false;
      btnText.classList.remove('hidden');
      btnLoading.classList.add('hidden');
    }
  });
</script>
