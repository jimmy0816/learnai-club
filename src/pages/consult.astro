---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="預約免費 30 分鐘 AI 策略諮詢"
  description="由服務過國泰人壽、華碩、TOTO 的 AI 顧問親自診斷，免費找出最值得優先導入 AI 的流程。"
>
  <!-- Hero -->
  <section style="background: #111111; padding: 72px 20px 56px;">
    <div style="max-width: 640px; margin: 0 auto; text-align: center;">
      <p style="font-size: 11px; font-weight: 600; color: var(--color-gold); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 20px;">免費策略諮詢</p>
      <h1 style="font-family: var(--font-heading); font-size: clamp(26px, 4vw, 40px); font-weight: 700; color: #f5f0e8; margin: 0 0 16px; line-height: 1.2;">
        預約免費 30 分鐘 AI 策略諮詢
      </h1>
      <p style="color: rgba(245,240,232,0.6); font-size: 16px; margin: 0; line-height: 1.7;">
        由服務過國泰人壽、華碩、TOTO 的 AI 顧問親自診斷
      </p>
    </div>
  </section>

  <!-- Form Section -->
  <section style="background: var(--color-bg-section); padding: 56px 20px 80px;">
    <div style="max-width: 640px; margin: 0 auto;">

      <!-- Value props -->
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 16px; margin-bottom: 40px;">
        <div style="background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 20px; text-align: center; box-shadow: var(--shadow-sm);">
          <div style="font-size: 13px; font-weight: 600; color: var(--color-text); margin-bottom: 4px;">找出最值得自動化的流程</div>
          <div style="font-size: 12px; color: var(--color-text-secondary);">精準診斷</div>
        </div>
        <div style="background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 20px; text-align: center; box-shadow: var(--shadow-sm);">
          <div style="font-size: 13px; font-weight: 600; color: var(--color-text); margin-bottom: 4px;">30 分鐘，具體可執行方案</div>
          <div style="font-size: 12px; color: var(--color-text-secondary);">高效率</div>
        </div>
        <div style="background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 20px; text-align: center; box-shadow: var(--shadow-sm);">
          <div style="font-size: 13px; font-weight: 600; color: var(--color-text); margin-bottom: 4px;">無銷售壓力，純乾貨</div>
          <div style="font-size: 12px; color: var(--color-text-secondary);">安心諮詢</div>
        </div>
      </div>

      <!-- Form Card -->
      <div id="form-card" style="background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 44px 40px; box-shadow: var(--shadow-sm);">
        <h2 style="font-family: var(--font-heading); font-size: 22px; font-weight: 600; color: var(--color-text); margin: 0 0 32px;">
          填寫諮詢資料
        </h2>

        <form id="consult-form" novalidate>
          <!-- Honeypot (spam prevention) -->
          <div style="display: none;" aria-hidden="true">
            <label>不要填這個欄位 <input type="text" name="_honeypot" tabindex="-1" autocomplete="off"></label>
          </div>

          <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
            <!-- Company -->
            <div style="grid-column: 1 / -1;">
              <label for="company" style="display: block; font-size: 13px; font-weight: 600; color: var(--color-text); margin-bottom: 8px; letter-spacing: 0.02em;">
                公司名稱 <span style="color: #cc4444;">*</span>
              </label>
              <input
                type="text"
                id="company"
                name="company"
                required
                placeholder="例：台灣製造股份有限公司"
                style="width: 100%; padding: 12px 16px; border: 1px solid var(--color-border); border-radius: var(--radius-sm); font-size: 15px; color: var(--color-text); background: var(--color-bg); box-sizing: border-box; transition: border-color 0.2s; outline: none; font-family: var(--font-body);"
                onfocus="this.style.borderColor='var(--color-primary)'; this.style.background='white';"
                onblur="this.style.borderColor='var(--color-border)'; this.style.background='var(--color-bg)';"
              >
            </div>

            <!-- Name -->
            <div>
              <label for="name" style="display: block; font-size: 13px; font-weight: 600; color: var(--color-text); margin-bottom: 8px; letter-spacing: 0.02em;">
                姓名 <span style="color: #cc4444;">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="王小明"
                style="width: 100%; padding: 12px 16px; border: 1px solid var(--color-border); border-radius: var(--radius-sm); font-size: 15px; color: var(--color-text); background: var(--color-bg); box-sizing: border-box; transition: border-color 0.2s; outline: none; font-family: var(--font-body);"
                onfocus="this.style.borderColor='var(--color-primary)'; this.style.background='white';"
                onblur="this.style.borderColor='var(--color-border)'; this.style.background='var(--color-bg)';"
              >
            </div>

            <!-- Title -->
            <div>
              <label for="job-title" style="display: block; font-size: 13px; font-weight: 600; color: var(--color-text); margin-bottom: 8px; letter-spacing: 0.02em;">
                職稱 <span style="color: #cc4444;">*</span>
              </label>
              <input
                type="text"
                id="job-title"
                name="title"
                required
                placeholder="IT 主管 / 業務協理"
                style="width: 100%; padding: 12px 16px; border: 1px solid var(--color-border); border-radius: var(--radius-sm); font-size: 15px; color: var(--color-text); background: var(--color-bg); box-sizing: border-box; transition: border-color 0.2s; outline: none; font-family: var(--font-body);"
                onfocus="this.style.borderColor='var(--color-primary)'; this.style.background='white';"
                onblur="this.style.borderColor='var(--color-border)'; this.style.background='var(--color-bg)';"
              >
            </div>

            <!-- Email -->
            <div>
              <label for="email" style="display: block; font-size: 13px; font-weight: 600; color: var(--color-text); margin-bottom: 8px; letter-spacing: 0.02em;">
                Email <span style="color: #cc4444;">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="you@company.com"
                style="width: 100%; padding: 12px 16px; border: 1px solid var(--color-border); border-radius: var(--radius-sm); font-size: 15px; color: var(--color-text); background: var(--color-bg); box-sizing: border-box; transition: border-color 0.2s; outline: none; font-family: var(--font-body);"
                onfocus="this.style.borderColor='var(--color-primary)'; this.style.background='white';"
                onblur="this.style.borderColor='var(--color-border)'; this.style.background='var(--color-bg)';"
              >
            </div>

            <!-- Phone -->
            <div>
              <label for="phone" style="display: block; font-size: 13px; font-weight: 600; color: var(--color-text); margin-bottom: 8px; letter-spacing: 0.02em;">
                電話 <span style="color: var(--color-text-secondary); font-weight: 400;">（選填）</span>
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="0912-345-678"
                style="width: 100%; padding: 12px 16px; border: 1px solid var(--color-border); border-radius: var(--radius-sm); font-size: 15px; color: var(--color-text); background: var(--color-bg); box-sizing: border-box; transition: border-color 0.2s; outline: none; font-family: var(--font-body);"
                onfocus="this.style.borderColor='var(--color-primary)'; this.style.background='white';"
                onblur="this.style.borderColor='var(--color-border)'; this.style.background='var(--color-bg)';"
              >
            </div>

            <!-- Needs -->
            <div style="grid-column: 1 / -1;">
              <label for="needs" style="display: block; font-size: 13px; font-weight: 600; color: var(--color-text); margin-bottom: 8px; letter-spacing: 0.02em;">
                需求簡述 <span style="color: #cc4444;">*</span>
              </label>
              <textarea
                id="needs"
                name="needs"
                required
                rows="4"
                placeholder="例如：我們想用 AI 優化客服流程"
                style="width: 100%; padding: 12px 16px; border: 1px solid var(--color-border); border-radius: var(--radius-sm); font-size: 15px; color: var(--color-text); background: var(--color-bg); box-sizing: border-box; resize: vertical; font-family: var(--font-body); transition: border-color 0.2s; outline: none; line-height: 1.7;"
                onfocus="this.style.borderColor='var(--color-primary)'; this.style.background='white';"
                onblur="this.style.borderColor='var(--color-border)'; this.style.background='var(--color-bg)';"
              ></textarea>
            </div>
          </div>

          <!-- Error message -->
          <div id="form-error" style="display: none; background: #fff0f0; border: 1px solid #e8b4b4; border-radius: var(--radius-sm); padding: 12px 16px; color: #c44; font-size: 14px; margin-bottom: 20px;"></div>

          <!-- Submit button -->
          <button
            type="submit"
            id="submit-btn"
            class="btn-primary"
            style="width: 100%; justify-content: center; font-size: 16px; padding: 16px 32px;"
          >
            送出諮詢 →
          </button>

          <p style="text-align: center; font-size: 12px; color: var(--color-text-secondary); opacity: 0.6; margin-top: 16px; margin-bottom: 0;">
            送出即代表同意我們與您聯繫以安排諮詢。
          </p>
        </form>

        <!-- Success message (hidden by default) -->
        <div id="success-msg" style="display: none; text-align: center; padding: 40px 0;">
          <div style="width: 56px; height: 56px; background: var(--color-bg-section); border: 1px solid var(--color-border); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; font-size: 24px;">✓</div>
          <h3 style="font-family: var(--font-heading); font-size: 22px; font-weight: 600; color: var(--color-text); margin: 0 0 12px;">
            已收到！我們會在 24 小時內回覆您。
          </h3>
          <p style="color: var(--color-text-secondary); font-size: 15px; margin-bottom: 28px;">
            感謝您預約諮詢，請留意 Email 通知。
          </p>
          <a href="/" class="btn-secondary">← 回到首頁</a>
        </div>
      </div>

    </div>
  </section>

  <style>
    @media (max-width: 480px) {
      .form-grid {
        grid-template-columns: 1fr !important;
      }
      .form-grid > div[style*="grid-column: 1 / -1"] {
        grid-column: 1 !important;
      }
      #form-card {
        padding: 28px 20px !important;
      }
    }
  </style>

  <script>
    const form = document.getElementById('consult-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const errorDiv = document.getElementById('form-error') as HTMLDivElement;
    const successMsg = document.getElementById('success-msg') as HTMLDivElement;

    // Auto-fill form from URL params (e.g. from AI 健檢 redirect)
    (function prefillFromUrl() {
      const params = new URLSearchParams(window.location.search);
      const fieldMap: Record<string, string> = {
        company: 'company',
        name: 'name',
        title: 'job-title',
        email: 'email',
        phone: 'phone',
      };
      Object.entries(fieldMap).forEach(([param, inputId]) => {
        const value = params.get(param);
        if (value) {
          const input = document.getElementById(inputId) as HTMLInputElement | null;
          if (input) input.value = value;
        }
      });
    })();

    // Auto-detect UTM source from URL
    function getUtmSource(): string {
      try {
        const params = new URLSearchParams(window.location.search);
        return params.get('utm_source') || params.get('ref') || document.referrer || '';
      } catch {
        return '';
      }
    }

    function showError(msg: string) {
      errorDiv.textContent = msg;
      errorDiv.style.display = 'block';
    }

    function hideError() {
      errorDiv.style.display = 'none';
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      hideError();

      const data = new FormData(form);
      const payload = {
        company: (data.get('company') as string)?.trim(),
        name: (data.get('name') as string)?.trim(),
        title: (data.get('title') as string)?.trim(),
        email: (data.get('email') as string)?.trim(),
        phone: (data.get('phone') as string)?.trim(),
        needs: (data.get('needs') as string)?.trim(),
        source: getUtmSource(),
        _honeypot: (data.get('_honeypot') as string)?.trim(),
      };

      // Client-side validation
      if (!payload.company || !payload.name || !payload.email || !payload.needs) {
        showError('請填寫所有必填欄位（標有 * 號）。');
        return;
      }

      // Loading state
      submitBtn.disabled = true;
      submitBtn.textContent = '送出中...';
      (submitBtn as HTMLButtonElement).style.background = '#9ca3af';
      (submitBtn as HTMLButtonElement).style.cursor = 'not-allowed';

      try {
        const res = await fetch('/api/consult', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const json = await res.json();

        if (json.success) {
          form.style.display = 'none';
          successMsg.style.display = 'block';
        } else {
          showError(json.error || '送出失敗，請稍後再試或直接寄信至 contact@learnai.club');
          submitBtn.disabled = false;
          submitBtn.textContent = '送出諮詢 →';
          (submitBtn as HTMLButtonElement).style.background = 'var(--color-primary)';
          (submitBtn as HTMLButtonElement).style.cursor = 'pointer';
        }
      } catch {
        showError('網路錯誤，請稍後再試或直接寄信至 contact@learnai.club');
        submitBtn.disabled = false;
        submitBtn.textContent = '送出諮詢 →';
        (submitBtn as HTMLButtonElement).style.background = 'var(--color-primary)';
        (submitBtn as HTMLButtonElement).style.cursor = 'pointer';
      }
    });
  </script>
</BaseLayout>
