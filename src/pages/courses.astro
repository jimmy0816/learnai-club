---
import Layout from '../layouts/Layout.astro';
---
<Layout title="開課 / 顧問">
  <!-- Hero -->
  <section class="relative py-20 px-6 md:px-12">
    <div class="max-w-7xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">開課 / 顧問</h1>
      <p class="text-xl text-[var(--muted)] max-w-2xl leading-relaxed">
        我正在規劃 AI 實戰工作坊——不是教你用 ChatGPT 寫文案，<br class="hidden md:block"/>
        是教你怎麼用 AI 建一整套自動化系統。
      </p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-6 md:px-12 pb-20">
    <!-- What you'll learn - Netflix card style -->
    <div class="rounded-lg bg-[var(--card)] overflow-hidden mb-10">
      <div class="h-1 w-full bg-[var(--accent)]"></div>
      <div class="p-8">
        <h2 class="text-2xl font-bold mb-6">你會學到的</h2>
        <div class="grid md:grid-cols-2 gap-4">
          <div class="flex gap-4 items-start p-4 rounded bg-[var(--bg)] hover:bg-[var(--card-hover)] transition-colors">
            <span class="text-2xl">⚡</span>
            <div>
              <p class="font-semibold text-[var(--text)]">AI 自動工作系統</p>
              <p class="text-sm text-[var(--muted)]">從零架設，真的跑起來的那種</p>
            </div>
          </div>
          <div class="flex gap-4 items-start p-4 rounded bg-[var(--bg)] hover:bg-[var(--card-hover)] transition-colors">
            <span class="text-2xl">🤖</span>
            <div>
              <p class="font-semibold text-[var(--text)]">AI Agent 社群管理</p>
              <p class="text-sm text-[var(--muted)]">自動產文、排程發布、多帳號管理</p>
            </div>
          </div>
          <div class="flex gap-4 items-start p-4 rounded bg-[var(--bg)] hover:bg-[var(--card-hover)] transition-colors">
            <span class="text-2xl">📊</span>
            <div>
              <p class="font-semibold text-[var(--text)]">即時 Dashboard</p>
              <p class="text-sm text-[var(--muted)]">監控所有系統狀態</p>
            </div>
          </div>
          <div class="flex gap-4 items-start p-4 rounded bg-[var(--bg)] hover:bg-[var(--card-hover)] transition-colors">
            <span class="text-2xl">💥</span>
            <div>
              <p class="font-semibold text-[var(--text)]">踩坑經驗</p>
              <p class="text-sm text-[var(--muted)]">每一步的踩坑經驗和解法</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Email form - Netflix style -->
    <div class="rounded-lg overflow-hidden bg-gradient-to-r from-[var(--accent)]/20 via-[var(--card)] to-[var(--card)] mb-10">
      <div class="p-8 relative">
        <div class="absolute top-0 left-0 w-1 h-full bg-[var(--accent)]"></div>
        <h2 class="text-2xl font-bold mb-2">搶先通知</h2>
        <p class="text-[var(--muted)] mb-6">留下 Email，開課第一時間通知你。不會寄垃圾信，保證。</p>
        <form action="#" method="POST" class="flex flex-col sm:flex-row gap-3">
          <input
            type="email"
            name="email"
            required
            placeholder="your@email.com"
            class="flex-1 px-4 py-3 rounded bg-[var(--bg)] border border-[var(--border)] text-[var(--text)] placeholder:text-[var(--muted-dim)] focus:outline-none focus:border-[var(--accent)] transition-colors"
          />
          <button type="submit" class="bg-[var(--accent)] hover:bg-[var(--accent-hover)] text-white font-bold px-8 py-3 rounded transition-colors cursor-pointer">
            我要搶先報名
          </button>
        </form>
      </div>
    </div>

    <!-- FAQ - Netflix style -->
    <div class="rounded-lg bg-[var(--card)] p-8">
      <h2 class="text-2xl font-bold mb-6">常見問題</h2>
      <div class="space-y-6">
        <div class="border-b border-[var(--border)] pb-6">
          <h3 class="font-bold text-[var(--text)] mb-2">需要會寫程式嗎？</h3>
          <p class="text-[var(--muted)]">有基礎最好（會用 Terminal、知道 API 是什麼），但不需要是工程師。</p>
        </div>
        <div class="border-b border-[var(--border)] pb-6">
          <h3 class="font-bold text-[var(--text)] mb-2">什麼時候開課？</h3>
          <p class="text-[var(--muted)]">預計 2026 Q3。先收名單，人數夠了就開。</p>
        </div>
        <div>
          <h3 class="font-bold text-[var(--text)] mb-2">跟其他 AI 課程有什麼不同？</h3>
          <p class="text-[var(--muted)]">這裡教的每一套系統，我自己每天都在用。不是 demo，是實戰。</p>
        </div>
      </div>
    </div>
  </div>
</Layout>
